# Crypto-Heranca Keeper Environment Variables

# Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Keeper Wallet (Base58 private key — keep secret!)
KEEPER_PRIVATE_KEY=your_base58_private_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Server
API_PORT=3000
API_RATE_LIMIT_PER_MINUTE=100

# Monitoring
MONITOR_INTERVAL_MINUTES=5
CLAIM_CHECK_INTERVAL_MINUTES=5

# Program ID
PROGRAM_ID=8rQWCAFD9GhyTmQ73Y4LkSt7VzxFhKgWwPC2kBHuPVyX

# Logging
LOG_LEVEL=info
